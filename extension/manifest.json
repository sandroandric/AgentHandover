{
  "manifest_version": 3,
  "name": "AgentHandover Observer",
  "version": "0.2.4",
  "description": "Silent observer for workflow learning - captures DOM snapshots, click intent, and accessibility metadata",
  "permissions": ["nativeMessaging", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "key": ""
}
