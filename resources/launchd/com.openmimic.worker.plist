<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.openmimic.worker</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/lib/openmimic/venv/bin/python</string>
        <string>-m</string>
        <string>oc_apprentice_worker</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>ProcessType</key>
    <string>Background</string>

    <key>LowPriorityBackgroundIO</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/com.openmimic.worker.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/com.openmimic.worker.stderr.log</string>

    <key>WorkingDirectory</key>
    <string>/usr/local/lib/openmimic</string>
</dict>
</plist>
