#!/bin/bash
# AgentHandover pre-install script — stops existing services if upgrading

# Resolve the real user's home — installer runs as root so $USER may be "root".
CONSOLE_USER=$(stat -f '%Su' /dev/console 2>/dev/null || echo "$USER")
USER_HOME=$(dscl . -read /Users/"${CONSOLE_USER}" NFSHomeDirectory 2>/dev/null | awk '{print $2}')
if [ -z "$USER_HOME" ] || [ ! -d "$USER_HOME" ]; then
    USER_HOME=$(eval echo ~"$CONSOLE_USER")
fi
LAUNCH_AGENTS="${USER_HOME}/Library/LaunchAgents"
CONSOLE_UID=$(id -u "${CONSOLE_USER}" 2>/dev/null || echo "501")

# Stop existing services using modern launchd API (bootout).
# The deprecated launchctl unload is broken on macOS 13+.
# Stop and remove daemon launchd job (daemon is now app-launched, not launchd)
sudo -u "${CONSOLE_USER}" launchctl bootout "gui/${CONSOLE_UID}/com.agenthandover.daemon" 2>/dev/null || true
sudo -u "${CONSOLE_USER}" launchctl disable "gui/${CONSOLE_UID}/com.agenthandover.daemon" 2>/dev/null || true
rm -f "${LAUNCH_AGENTS}/com.agenthandover.daemon.plist" 2>/dev/null

# Remove old daemon from inside app bundle (moved to /usr/local/lib/agenthandover/).
# Having it inside the bundle caused codesign --deep to register it as a second TCC principal.
rm -rf /Applications/AgentHandover.app/Contents/Helpers/AgentHandoverDaemon.app 2>/dev/null || true
rm -f /Applications/AgentHandover.app/Contents/Helpers/ah-observer 2>/dev/null || true

sudo -u "${CONSOLE_USER}" launchctl bootout "gui/${CONSOLE_UID}/com.agenthandover.worker" 2>/dev/null || true

# Kill any running daemon process (may have been app-launched)
killall ah-observer 2>/dev/null || true

# Remove Chromium-family native host manifests until the app reaches
# extension setup. Any stale manifest can respawn ah-observer during
# onboarding and surface it as the Screen Recording principal.
for browser_dir in \
    "Google/Chrome" \
    "Chromium" \
    "BraveSoftware/Brave-Browser" \
    "Microsoft Edge" \
    "Arc/User Data"; do
    rm -f "${USER_HOME}/Library/Application Support/${browser_dir}/NativeMessagingHosts/com.agenthandover.host.json" 2>/dev/null || true
done

# Remove legacy openmimic services
sudo -u "${CONSOLE_USER}" launchctl bootout "gui/${CONSOLE_UID}/com.openmimic.daemon" 2>/dev/null || true
sudo -u "${CONSOLE_USER}" launchctl bootout "gui/${CONSOLE_UID}/com.openmimic.worker" 2>/dev/null || true
rm -f "${LAUNCH_AGENTS}/com.openmimic.daemon.plist" 2>/dev/null
rm -f "${LAUNCH_AGENTS}/com.openmimic.worker.plist" 2>/dev/null

echo "Pre-install complete."
exit 0
