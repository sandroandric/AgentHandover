#!/bin/bash
# AgentHandover post-install script
set -e

# Track non-fatal warnings that shouldn't abort install but should be reported.
WARNINGS=""
warn() { WARNINGS="${WARNINGS}\n  ⚠ $1"; }

# Resolve the real user's home — installer runs as root so $USER may be "root".
# Use the console owner (the logged-in user) as the target.
CONSOLE_USER=$(stat -f '%Su' /dev/console 2>/dev/null || echo "$USER")
USER_HOME=$(dscl . -read /Users/"${CONSOLE_USER}" NFSHomeDirectory 2>/dev/null | awk '{print $2}')
if [ -z "$USER_HOME" ] || [ ! -d "$USER_HOME" ]; then
    USER_HOME=$(eval echo ~"$CONSOLE_USER")
fi
DATA_DIR="${USER_HOME}/Library/Application Support/agenthandover"
LAUNCH_AGENTS="${USER_HOME}/Library/LaunchAgents"
LIB_DIR="/usr/local/lib/agenthandover"

# Create data directories
mkdir -p "${DATA_DIR}/logs"
mkdir -p "${DATA_DIR}/artifacts"

# Write launchd plists with user-specific log paths
# (cannot use static plists because log paths need the real user's home)
mkdir -p "${LAUNCH_AGENTS}"
LOG_DIR="${DATA_DIR}/logs"

cp "${LIB_DIR}/launchd/com.agenthandover.daemon.plist" "${LAUNCH_AGENTS}/"
sed -i '' \
    -e "s|/tmp/com.agenthandover.daemon.stdout.log|${LOG_DIR}/daemon.stdout.log|" \
    -e "s|/tmp/com.agenthandover.daemon.stderr.log|${LOG_DIR}/daemon.stderr.log|" \
    "${LAUNCH_AGENTS}/com.agenthandover.daemon.plist"

cp "${LIB_DIR}/launchd/com.agenthandover.worker.plist" "${LAUNCH_AGENTS}/"
sed -i '' \
    -e "s|/tmp/com.agenthandover.worker.stdout.log|${LOG_DIR}/worker.stdout.log|" \
    -e "s|/tmp/com.agenthandover.worker.stderr.log|${LOG_DIR}/worker.stderr.log|" \
    "${LAUNCH_AGENTS}/com.agenthandover.worker.plist"

# Create default config if none exists
if [ ! -f "${DATA_DIR}/config.toml" ]; then
    cat > "${DATA_DIR}/config.toml" << 'TOML'
# AgentHandover Configuration
# See https://github.com/sandroandric/AgentHandover for documentation

[observer]
t_dwell_seconds = 3
t_scroll_read_seconds = 8
capture_screenshots = true
screenshot_max_per_minute = 20

[privacy]
enable_inline_secret_redaction = true
secure_field_drop = true

[storage]
retention_days_raw = 14
retention_days_episodes = 90

[export]
adapter = "openclaw"
json_export = false
TOML
fi

# Install Chrome native messaging host manifest
NM_DIR="${USER_HOME}/Library/Application Support/Google/Chrome/NativeMessagingHosts"
mkdir -p "${NM_DIR}"
cat > "${NM_DIR}/com.agenthandover.host.json" << JSON
{
    "name": "com.agenthandover.host",
    "description": "AgentHandover native messaging host",
    "path": "/usr/local/bin/agenthandover-daemon",
    "type": "stdio",
    "args": ["--native-messaging"],
    "allowed_origins": [
        "chrome-extension://knldjmfmopnpolahpmmgbagdohdnhkik/"
    ]
}
JSON

# Set up Python virtual environment for worker (non-fatal: worker is optional
# on first install — user can run `agenthandover setup --vlm` later).
if [ ! -d "${LIB_DIR}/venv" ]; then
    if python3 -m venv "${LIB_DIR}/venv" 2>/dev/null && \
       "${LIB_DIR}/venv/bin/pip" install --quiet "${LIB_DIR}/worker/" 2>/dev/null; then
        echo "  Python virtual environment created."
    else
        warn "Python venv creation failed. Run: python3 -m venv ${LIB_DIR}/venv && ${LIB_DIR}/venv/bin/pip install ${LIB_DIR}/worker/"
    fi
fi

# Set proper permissions
chmod 755 /usr/local/bin/agenthandover-daemon
chmod 755 /usr/local/bin/agenthandover

# Chrome extension setup (informational only — never fatal)
EXT_DIR="${LIB_DIR}/extension"
if [ -f "${EXT_DIR}/manifest.json" ] && [ -f "${EXT_DIR}/background.js" ]; then
    echo "Chrome extension pre-built and ready."
    echo "  Load it in Chrome: chrome://extensions -> Load unpacked -> ${EXT_DIR}"
elif [ -d "${EXT_DIR}/src" ]; then
    echo ""
    echo "Chrome extension source is included but not pre-built."
    echo "To build the extension:"
    echo "  cd ${EXT_DIR}"
    echo "  npm install && npm run build"
    echo "Then load in Chrome: chrome://extensions -> Load unpacked -> ${EXT_DIR}/dist"
else
    echo ""
    echo "Chrome extension not included in this package."
    echo "To install it from source:"
    echo "  git clone https://github.com/sandroandric/AgentHandover.git"
    echo "  cd AgentHandover/extension && npm install && npm run build"
    echo "Then load in Chrome: chrome://extensions -> Load unpacked -> extension/dist"
fi

echo ""
if [ -n "$WARNINGS" ]; then
    echo "AgentHandover installed with warnings:"
    echo -e "$WARNINGS"
    echo ""
    echo "Run 'agenthandover doctor' to diagnose issues."
    exit 0
else
    echo "AgentHandover installed successfully."
    echo "Run 'agenthandover doctor' to verify the installation."
    exit 0
fi
