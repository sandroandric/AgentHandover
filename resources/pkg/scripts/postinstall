#!/bin/bash
# AgentHandover post-install script
set -e

# Track non-fatal warnings that shouldn't abort install but should be reported.
WARNINGS=""
warn() { WARNINGS="${WARNINGS}\n  ⚠ $1"; }

# Resolve the real user's home — installer runs as root so $USER may be "root".
# Use the console owner (the logged-in user) as the target.
CONSOLE_USER=$(stat -f '%Su' /dev/console 2>/dev/null || echo "$USER")
USER_HOME=$(dscl . -read /Users/"${CONSOLE_USER}" NFSHomeDirectory 2>/dev/null | awk '{print $2}')
if [ -z "$USER_HOME" ] || [ ! -d "$USER_HOME" ]; then
    USER_HOME=$(eval echo ~"$CONSOLE_USER")
fi
CONSOLE_UID=$(id -u "${CONSOLE_USER}" 2>/dev/null || echo "501")
DATA_DIR="${USER_HOME}/Library/Application Support/agenthandover"
LAUNCH_AGENTS="${USER_HOME}/Library/LaunchAgents"
LIB_DIR="/usr/local/lib/agenthandover"

# Create data directories (owned by the user, not root)
mkdir -p "${DATA_DIR}/logs"
mkdir -p "${DATA_DIR}/artifacts"
chown -R "${CONSOLE_USER}" "${DATA_DIR}"

# Write launchd plists with user-specific log paths
# (cannot use static plists because log paths need the real user's home)
mkdir -p "${LAUNCH_AGENTS}"
LOG_DIR="${DATA_DIR}/logs"

# Daemon is launched as an app bundle by the menu bar app (not launchd).
# Only the worker uses launchd.
cp "${LIB_DIR}/launchd/com.agenthandover.worker.plist" "${LAUNCH_AGENTS}/"
sed -i '' \
    -e "s|/tmp/com.agenthandover.worker.stdout.log|${LOG_DIR}/worker.stdout.log|" \
    -e "s|/tmp/com.agenthandover.worker.stderr.log|${LOG_DIR}/worker.stderr.log|" \
    "${LAUNCH_AGENTS}/com.agenthandover.worker.plist"

chown "${CONSOLE_USER}" "${LAUNCH_AGENTS}/com.agenthandover.worker.plist"

# Create default config if none exists
if [ ! -f "${DATA_DIR}/config.toml" ]; then
    cat > "${DATA_DIR}/config.toml" << 'TOML'
# AgentHandover Configuration
# See https://github.com/sandroandric/AgentHandover for documentation

[observer]
t_dwell_seconds = 3
t_scroll_read_seconds = 8
capture_screenshots = true
screenshot_max_per_minute = 20

[privacy]
enable_inline_secret_redaction = true
secure_field_drop = true

[storage]
retention_days_raw = 14
retention_days_episodes = 90

[export]
adapter = "openclaw"
json_export = false
TOML
fi

# Remove any stale Chromium-family native host manifest. The app now installs
# these only when the extension step is reached or onboarding is already
# complete, so the daemon cannot be spawned during first-run permission setup.
for browser_dir in \
    "Google/Chrome" \
    "Chromium" \
    "BraveSoftware/Brave-Browser" \
    "Microsoft Edge" \
    "Arc/User Data"; do
    BROWSER_ROOT="${USER_HOME}/Library/Application Support/${browser_dir}"
    if [ -d "${BROWSER_ROOT}" ]; then
        mkdir -p "${BROWSER_ROOT}/NativeMessagingHosts"
        rm -f "${BROWSER_ROOT}/NativeMessagingHosts/com.agenthandover.host.json"
    fi
done

# Set up Python virtual environment for worker.
# The worker is required for VLM annotation and SOP generation — without it,
# AgentHandover cannot function. Treat failure as fatal.
if [ ! -d "${LIB_DIR}/venv" ]; then
    # Find Python 3.11+ — installer runs as root so PATH is minimal.
    # Search common locations before falling back to system python3.
    PYTHON3=""
    for candidate in \
        /opt/homebrew/bin/python3 \
        /usr/local/bin/python3 \
        /opt/homebrew/bin/python3.14 \
        /opt/homebrew/bin/python3.13 \
        /opt/homebrew/bin/python3.12 \
        /opt/homebrew/bin/python3.11 \
        /usr/local/bin/python3.13 \
        /usr/local/bin/python3.12 \
        /usr/local/bin/python3.11 \
        /Library/Frameworks/Python.framework/Versions/3.14/bin/python3 \
        /Library/Frameworks/Python.framework/Versions/3.13/bin/python3 \
        /Library/Frameworks/Python.framework/Versions/3.12/bin/python3 \
        /Library/Frameworks/Python.framework/Versions/3.11/bin/python3 \
        "$(which python3 2>/dev/null)" \
        python3; do
        if [ -x "$candidate" ] 2>/dev/null; then
            ver=$("$candidate" -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")' 2>/dev/null || echo "0.0")
            major=$(echo "$ver" | cut -d. -f1)
            minor=$(echo "$ver" | cut -d. -f2)
            if [ "$major" -ge 3 ] 2>/dev/null && [ "$minor" -ge 11 ] 2>/dev/null; then
                PYTHON3="$candidate"
                break
            fi
        fi
    done

    if [ -z "$PYTHON3" ]; then
        echo "ERROR: Python 3.11+ not found. AgentHandover requires Python 3.11 or later."
        echo "Install Python from https://www.python.org/downloads/ or via: brew install python@3.13"
        exit 1
    fi

    echo "  Using Python: $PYTHON3"
    PYTHON_VERSION=$("$PYTHON3" -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")' 2>/dev/null)
    echo "  Python version: ${PYTHON_VERSION}"

    # Create venv as the real user (not root) so future pip installs
    # don't require sudo. The installer runs as root but the venv
    # should be owned by the console user.
    chown -R "${CONSOLE_USER}" "${LIB_DIR}"
    if ! sudo -u "${CONSOLE_USER}" "$PYTHON3" -m venv "${LIB_DIR}/venv"; then
        echo "ERROR: Failed to create Python virtual environment at ${LIB_DIR}/venv."
        echo "Try manually: $PYTHON3 -m venv ${LIB_DIR}/venv"
        exit 1
    fi

    if ! sudo -u "${CONSOLE_USER}" "${LIB_DIR}/venv/bin/pip" install --quiet "${LIB_DIR}/worker/"; then
        echo "ERROR: Failed to install AgentHandover worker Python package."
        echo "Try manually: ${LIB_DIR}/venv/bin/pip install ${LIB_DIR}/worker/"
        rm -rf "${LIB_DIR}/venv"
        exit 1
    fi

    # Install optional dependencies for image embeddings (Apple Silicon only)
    sudo -u "${CONSOLE_USER}" "${LIB_DIR}/venv/bin/pip" install --quiet "mlx-embeddings>=0.0.4" 2>/dev/null || true

    # Ensure the venv is owned by the user, not root
    chown -R "${CONSOLE_USER}" "${LIB_DIR}/venv"

    echo "  Python virtual environment created."
else
    # Venv exists — reinstall worker package to pick up code changes
    echo "  Updating worker package..."
    sudo -u "${CONSOLE_USER}" "${LIB_DIR}/venv/bin/pip" install --quiet --force-reinstall --no-deps "${LIB_DIR}/worker/" 2>/dev/null || true
    # Ensure mlx-embeddings is installed
    sudo -u "${CONSOLE_USER}" "${LIB_DIR}/venv/bin/pip" install --quiet "mlx-embeddings>=0.0.4" 2>/dev/null || true
fi

# Set proper permissions
chmod 755 /usr/local/lib/agenthandover/ah-observer
chmod 755 /usr/local/bin/agenthandover

# Clear stale daemon TCC identity so users only ever see AgentHandover in
# System Settings going forward. This does not reset the main app grant.
sudo -u "${CONSOLE_USER}" tccutil reset ScreenCapture com.agenthandover.daemon 2>/dev/null || true
sudo -u "${CONSOLE_USER}" tccutil reset Accessibility com.agenthandover.daemon 2>/dev/null || true
sudo -u "${CONSOLE_USER}" launchctl disable "gui/${CONSOLE_UID}/com.agenthandover.daemon" 2>/dev/null || true

# Only reset onboarding on FRESH install (data dir didn't exist before)
if [ ! -f "${DATA_DIR}/config.toml.bak" ]; then
    sudo -u "${CONSOLE_USER}" defaults write com.agenthandover.app hasCompletedOnboarding -bool false 2>/dev/null || true
fi
# Mark that install has run (for upgrade detection)
touch "${DATA_DIR}/config.toml.bak" 2>/dev/null || true

# Chrome extension setup (informational only — never fatal)
EXT_DIR="${LIB_DIR}/extension"
if [ -f "${EXT_DIR}/manifest.json" ] && [ -f "${EXT_DIR}/background.js" ]; then
    echo "Chrome extension pre-built and ready."
    echo "  Load it in Chrome: chrome://extensions -> Load unpacked -> ${EXT_DIR}"
elif [ -d "${EXT_DIR}/src" ]; then
    echo ""
    echo "Chrome extension source is included but not pre-built."
    echo "To build the extension:"
    echo "  cd ${EXT_DIR}"
    echo "  npm install && npm run build"
    echo "Then load in Chrome: chrome://extensions -> Load unpacked -> ${EXT_DIR}/dist"
else
    echo ""
    echo "Chrome extension not included in this package."
    echo "To install it from source:"
    echo "  git clone https://github.com/sandroandric/AgentHandover.git"
    echo "  cd AgentHandover/extension && npm install && npm run build"
    echo "Then load in Chrome: chrome://extensions -> Load unpacked -> extension/dist"
fi

# Register launchd services (RunAtLoad=false, so they won't start yet)
# Only the worker uses launchd now. The daemon is started directly by the app.
# Use modern launchctl bootstrap (load/unload deprecated on macOS 13+)
sudo -u "${CONSOLE_USER}" launchctl bootstrap "gui/${CONSOLE_UID}" "${LAUNCH_AGENTS}/com.agenthandover.worker.plist" 2>/dev/null || true
echo "  Services registered (will start when app launches)."

# Launch the menu bar app (as the real user, not root)
if [ -d "/Applications/AgentHandover.app" ]; then
    sudo -u "${CONSOLE_USER}" open /Applications/AgentHandover.app 2>/dev/null || true
    echo "AgentHandover app launched — check your menu bar."
fi

echo ""
if [ -n "$WARNINGS" ]; then
    echo "AgentHandover installed with warnings:"
    echo -e "$WARNINGS"
    echo ""
    echo "Run 'agenthandover doctor' to diagnose issues."
    exit 0
else
    echo "AgentHandover installed successfully."
    exit 0
fi
