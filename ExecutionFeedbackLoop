 Part C: Execution-Driven Skill Improvement

 Goal: Process execution results to systematically improve procedures.

 C1. New file: worker/src/agenthandover_worker/skill_improver.py

 class SkillImprover:
     def __init__(self, kb, lifecycle_manager, staleness_detector):
         ...

     def process_execution(self, record: ExecutionRecord,
                           observed: dict | None = None) -> list[str]:
         """Process a completed execution. Returns list of improvements made."""
         improvements = []
         slug = record.procedure_slug
         proc = self._kb.get_procedure(slug)
         if proc is None:
             return improvements

         if record.status == ExecutionStatus.COMPLETED:
             improvements += self._handle_success(slug, proc, record, observed)
         elif record.status == ExecutionStatus.DEVIATED:
             improvements += self._handle_deviation(slug, proc, record, observed)
         elif record.status == ExecutionStatus.FAILED:
             improvements += self._handle_failure(slug, proc, record)

         self._kb.save_procedure(proc)
         return improvements

     def _handle_success(self, slug, proc, record, observed):
         """Success: boost confidence, confirm freshness, update timing."""
         improvements = []
         # 1. Update last_confirmed
         proc["staleness"]["last_confirmed"] = datetime.now(tz=UTC).isoformat()
         improvements.append("updated_last_confirmed")

         # 2. Boost confidence (small increment per success, cap at 1.0)
         current = proc.get("confidence_avg", 0.5)
         proc["confidence_avg"] = min(1.0, current + 0.02)
         proc["staleness"]["confidence_trend"].append(proc["confidence_avg"])
         improvements.append("boosted_confidence")

         # 3. Update timing if available
         if record.completed_at and record.started_at:
             duration = _compute_duration_minutes(record.started_at, record.completed_at)
             rhythm = proc.setdefault("workflow_rhythm", {})
             prev = rhythm.get("avg_duration_minutes")
             if prev:
                 rhythm["avg_duration_minutes"] = prev * 0.7 + duration * 0.3  # EMA
             else:
                 rhythm["avg_duration_minutes"] = duration
             improvements.append("updated_timing")

         # 4. Track in execution_stats
         stats = proc.setdefault("execution_stats", {"total": 0, "success": 0, "failed": 0, "deviated": 0})
         stats["total"] += 1
         stats["success"] += 1
         stats["last_executed"] = record.completed_at
         stats["success_rate"] = stats["success"] / stats["total"]

         return improvements

     def _handle_deviation(self, slug, proc, record, observed):
         """Deviation: add drift signal, track alternatives, suggest updates."""
         improvements = []

         # 1. Add drift signal
         proc["staleness"]["drift_signals"].append({
             "type": "execution_deviation",
             "detail": f"{len(record.deviations)} step(s) deviated",
             "first_seen": record.completed_at,
         })
         improvements.append("added_drift_signal")

         # 2. Track observed alternatives for each deviated step
         alternatives = proc.setdefault("observed_alternatives", [])
         for dev in record.deviations:
             step_id = dev.get("step_id")
             detail = dev.get("detail", "")
             alternatives.append({
                 "step_id": step_id,
                 "observed_action": detail,
                 "execution_id": record.execution_id,
                 "timestamp": record.completed_at,
             })

         # 3. If same alternative seen 2+ times, queue curation suggestion
         alt_counts = _count_alternatives(alternatives)
         for step_id, alts in alt_counts.items():
             if len(alts) >= 2:
                 improvements.append(f"branch_suggested:{step_id}")

         # 4. Update execution_stats
         stats = proc.setdefault("execution_stats", {"total": 0, "success": 0, "failed": 0, "deviated": 0})
         stats["total"] += 1
         stats["deviated"] += 1
         stats["last_executed"] = record.completed_at
         stats["success_rate"] = stats["success"] / stats["total"]

         return improvements

     def _handle_failure(self, slug, proc, record):
         """Failure: reduce confidence, potentially demote."""
         improvements = []

         # 1. Add drift signal
         proc["staleness"]["drift_signals"].append({
             "type": "execution_failure",
             "detail": f"Agent execution failed: {record.error or 'unknown'}",
             "first_seen": record.completed_at,
         })

         # 2. Reduce confidence
         current = proc.get("confidence_avg", 0.5)
         proc["confidence_avg"] = max(0.0, current - 0.05)
         proc["staleness"]["confidence_trend"].append(proc["confidence_avg"])
         improvements.append("reduced_confidence")

         # 3. Update execution_stats
         stats = proc.setdefault("execution_stats", {"total": 0, "success": 0, "failed": 0, "deviated": 0})
         stats["total"] += 1
         stats["failed"] += 1
         stats["last_executed"] = record.completed_at
         stats["success_rate"] = stats["success"] / stats["total"]

         # 4. Auto-demotion handled by existing EscalationHandler (already wired)
         # Just ensure stats are saved — escalation reads from execution history

         return improvements

